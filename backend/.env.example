# ZenForge Configuration
# Copy this to .env and adjust as needed

# Application
DEBUG=false

# Ollama Configuration (local LLM)
# For Docker: http://host.docker.internal:11434
# For WSL:    http://172.29.240.1:11434
# For native: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Embedding Model (downloads once, then cached locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_SIZE_MB=50

# RAG Configuration
TOP_K_RETRIEVAL=4
SIMILARITY_THRESHOLD=0.3
